<%= render "shared/form_errors", object: employee %>

<div class="space-y-4">
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :name, "姓名", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.text_field :name,
            placeholder: "例：陳大明",
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
    </div>
    <div>
      <%= f.label :phone, "電話（選填）", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.telephone_field :phone,
            placeholder: "09xx-xxx-xxx",
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :location_id, "主要門市", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.select :location_id,
            options_from_collection_for_select(@locations, :id, :name, employee.location_id),
            { prompt: "選擇門市" },
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent bg-white" %>
    </div>
    <div>
      <%= f.label :status, "狀態", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.select :status,
            [["在職", "active"], ["待入職", "pending"], ["離職", "inactive"]],
            { selected: employee.status || "active" },
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent bg-white" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :start_on, "到職日（選填）", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.date_field :start_on,
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
    </div>
    <div>
      <%= f.label :end_on, "離職日（選填）", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.date_field :end_on,
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit "儲存員工",
          class: "bg-orange-500 hover:bg-orange-600 text-white font-medium px-6 py-2.5 rounded-lg transition cursor-pointer text-sm" %>
    <%= link_to "取消", employees_path,
          class: "px-6 py-2.5 text-sm text-slate-600 hover:text-slate-900 transition" %>
  </div>
</div>
