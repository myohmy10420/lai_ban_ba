<%= render "shared/form_errors", object: shift %>

<div class="space-y-4">
  <div>
    <%= f.label :location_id, "門市", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.select :location_id,
          options_from_collection_for_select(@locations, :id, :name, shift.location_id),
          { prompt: "選擇門市" },
          class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent bg-white" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :role_tag, "職位", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.select :role_tag,
            [["外場", "floor"], ["內場", "kitchen"], ["收銀", "cashier"]],
            { selected: shift.role_tag },
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent bg-white" %>
    </div>
    <div>
      <%= f.label :required_headcount, "需要人數", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.number_field :required_headcount,
            min: 1, max: 20,
            value: shift.required_headcount || 1,
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
    </div>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :starts_at, "開始時間", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.datetime_local_field :starts_at,
            value: shift.starts_at&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
    </div>
    <div>
      <%= f.label :ends_at, "結束時間", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
      <%= f.datetime_local_field :ends_at,
            value: shift.ends_at&.strftime("%Y-%m-%dT%H:%M"),
            class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
    </div>
  </div>

  <%= f.hidden_field :lock_version %>

  <div class="flex gap-3 pt-2">
    <%= f.submit "儲存班次",
          class: "bg-orange-500 hover:bg-orange-600 text-white font-medium px-6 py-2.5 rounded-lg transition cursor-pointer text-sm" %>
    <%= link_to "取消", shifts_path,
          class: "px-6 py-2.5 text-sm text-slate-600 hover:text-slate-900 transition" %>
  </div>
</div>
