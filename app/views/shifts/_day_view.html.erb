<%# 日期導覽 %>
<div class="flex items-center gap-3 mb-5">
  <%= link_to shifts_path(date: (@date - 1.day).to_s),
        class: "p-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition" do %>
    <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  <% end %>

  <div class="bg-white border border-slate-200 rounded-lg px-4 py-2 text-sm font-medium text-slate-700">
    <%= @date.strftime("%Y年 %-m月 %-d日") %>
    <% if @date == Date.today %>
      <span class="ml-1 text-xs text-orange-500">今天</span>
    <% end %>
  </div>

  <%= link_to shifts_path(date: (@date + 1.day).to_s),
        class: "p-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition" do %>
    <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  <% end %>

  <% unless @date == Date.today %>
    <%= link_to "今天", shifts_path, class: "text-sm text-orange-500 hover:text-orange-600 ml-1" %>
  <% end %>

  <%# 複製上週按鈕 %>
  <div class="ml-auto flex items-center gap-2">
    <% if flash[:confirm_copy] %>
      <span class="text-xs text-slate-500">當天已有 <%= flash[:confirm_copy][:count] %> 個班次，確定覆蓋？</span>
      <%= button_to "確定覆蓋",
            copy_from_last_week_shifts_path,
            method: :post,
            params: { date: @date.to_s, overwrite: "true" },
            class: "text-xs text-white bg-red-500 hover:bg-red-600 px-3 py-1.5 rounded-lg transition cursor-pointer" %>
      <%= link_to "取消", shifts_path(date: @date.to_s),
            class: "text-xs text-slate-500 hover:text-slate-700" %>
    <% else %>
      <%= button_to "複製上週班表",
            copy_from_last_week_shifts_path,
            method: :post,
            params: { date: @date.to_s },
            class: "text-xs text-slate-600 border border-slate-300 bg-white hover:bg-slate-50 px-3 py-1.5 rounded-lg transition cursor-pointer" %>
    <% end %>
  </div>
</div>

<%# 班次列表 %>
<% if @shifts.empty? %>
  <div class="bg-white rounded-xl border border-slate-200 py-16 text-center">
    <svg class="w-12 h-12 text-slate-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
    </svg>
    <p class="text-slate-400 text-sm">這天沒有班次</p>
    <%= link_to "新增班次", new_shift_path, class: "mt-2 inline-block text-sm text-orange-500 hover:underline" %>
  </div>
<% else %>
  <div class="space-y-3">
    <% @shifts.each do |shift| %>
      <%= link_to shift_path(shift), class: "block bg-white rounded-xl border border-slate-200 px-5 py-4 hover:border-orange-300 transition" do %>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="text-center">
              <div class="text-lg font-bold text-slate-800">
                <%= shift.starts_at.strftime("%H:%M") %> – <%= shift.ends_at.strftime("%H:%M") %>
              </div>
              <div class="text-xs text-slate-400"><%= shift.duration_hours %>hr</div>
            </div>
            <div class="w-px h-10 bg-slate-200"></div>
            <div>
              <div class="font-medium text-slate-700"><%= shift.location.name %></div>
              <div class="flex items-center gap-2 mt-0.5">
                <span class="px-2 py-0.5 bg-slate-100 text-slate-500 rounded text-xs">
                  <%= ApplicationHelper::ROLE_TAG_I18N[shift.role_tag] || shift.role_tag %>
                </span>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <%= render "shifts/staffing_bar", shift: shift %>
            <% if shift.shift_assignments.any? %>
              <div class="flex -space-x-2">
                <% shift.shift_assignments.first(3).each do |sa| %>
                  <div class="w-7 h-7 bg-orange-100 border-2 border-white rounded-full flex items-center justify-center text-xs font-medium text-orange-600">
                    <%= sa.employee.name.first %>
                  </div>
                <% end %>
                <% if shift.shift_assignments.size > 3 %>
                  <div class="w-7 h-7 bg-slate-200 border-2 border-white rounded-full flex items-center justify-center text-xs text-slate-500">
                    +<%= shift.shift_assignments.size - 3 %>
                  </div>
                <% end %>
              </div>
            <% end %>
            <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
