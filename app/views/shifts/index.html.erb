<% content_for :page_title, "班表" %>
<% content_for :header_actions do %>
  <div class="flex items-center gap-2">
    <%# 視角切換 %>
    <%
      week_date  = @view_mode == "week"  ? @week_start.to_s  : @view_mode == "month" ? @month_start.beginning_of_week(:sunday).to_s : nil
      month_date = @view_mode == "month" ? @month_start.to_s : @view_mode == "week"  ? @week_start.beginning_of_month.to_s          : nil
    %>
    <div class="flex rounded-lg border border-slate-200 overflow-hidden text-sm">
      <%= link_to "週", shifts_path(view: "week", date: week_date),
            class: "px-3 py-1.5 transition #{@view_mode == 'week' ? 'bg-orange-500 text-white' : 'bg-white text-slate-600 hover:bg-slate-50'}" %>
      <%= link_to "月", shifts_path(view: "month", date: month_date),
            class: "px-3 py-1.5 transition #{@view_mode == 'month' ? 'bg-orange-500 text-white' : 'bg-white text-slate-600 hover:bg-slate-50'}" %>
    </div>
    <%= link_to "新增班次", new_shift_path,
          class: "bg-orange-500 hover:bg-orange-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
  </div>
<% end %>

<% if @view_mode == "month" %>
  <%= render "shifts/month_view" %>
<% else %>
  <%= render "shifts/week_view" %>
<% end %>
