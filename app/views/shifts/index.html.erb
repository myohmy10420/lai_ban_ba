<% content_for :page_title, "班表" %>
<% content_for :header_actions do %>
  <div class="flex items-center gap-2">
    <%# 視角切換 %>
    <div class="flex rounded-lg border border-slate-200 overflow-hidden text-sm">
      <%= link_to "日", shifts_path(view: "day", date: (@view_mode == "week" ? @week_start.to_s : @date&.to_s)),
            class: "px-3 py-1.5 transition #{@view_mode == 'day' ? 'bg-orange-500 text-white' : 'bg-white text-slate-600 hover:bg-slate-50'}" %>
      <%= link_to "週", shifts_path(view: "week", date: (@view_mode == "week" ? @week_start.to_s : @date&.to_s)),
            class: "px-3 py-1.5 transition #{@view_mode == 'week' ? 'bg-orange-500 text-white' : 'bg-white text-slate-600 hover:bg-slate-50'}" %>
    </div>
    <%= link_to "新增班次", new_shift_path,
          class: "bg-orange-500 hover:bg-orange-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition" %>
  </div>
<% end %>

<% if @view_mode == "week" %>
  <%= render "shifts/week_view" %>
<% else %>
  <%= render "shifts/day_view" %>
<% end %>
