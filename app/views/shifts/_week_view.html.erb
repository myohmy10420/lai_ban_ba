<%# 週導覽 %>
<div class="flex items-center gap-3 mb-4">
  <%= link_to shifts_path(view: "week", date: (@week_start - 7.days).to_s),
        class: "p-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition" do %>
    <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  <% end %>
  <div class="bg-white border border-slate-200 rounded-lg px-4 py-2 text-sm font-medium text-slate-700">
    <%= @week_start.strftime("%-m/%-d") %> – <%= (@week_start + 6.days).strftime("%-m/%-d") %>
  </div>
  <%= link_to shifts_path(view: "week", date: (@week_start + 7.days).to_s),
        class: "p-2 rounded-lg border border-slate-200 bg-white hover:bg-slate-50 transition" do %>
    <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  <% end %>
  <% unless @week_start == Date.today.beginning_of_week(:sunday) %>
    <%= link_to "本週", shifts_path(view: "week"), class: "text-sm text-orange-500 hover:text-orange-600 ml-1" %>
  <% end %>
</div>

<%# 油漆刷 wrapper（toolbar + 週曆共用同一個 controller）%>
<div data-controller="paintbrush" data-paintbrush-active-value="false">
<div class="bg-white border border-slate-200 rounded-xl p-4 mb-4">
  <div class="flex items-end gap-4 flex-wrap">
    <div>
      <label class="block text-xs font-medium text-slate-500 mb-1">門市</label>
      <%= select_tag "pb_location",
            options_from_collection_for_select(@locations, :id, :name),
            prompt: "選擇門市",
            class: "border border-slate-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 bg-white",
            data: { paintbrush_target: "location" } %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500 mb-1">職位</label>
      <%= select_tag "pb_role",
            options_for_select([["外場", "floor"], ["內場", "kitchen"], ["收銀", "cashier"]]),
            class: "border border-slate-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 bg-white",
            data: { paintbrush_target: "roleTag" } %>
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500 mb-1">開始</label>
      <input type="time" value="09:00"
             class="border border-slate-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"
             data-paintbrush-target="startsAt">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500 mb-1">結束</label>
      <input type="time" value="17:00"
             class="border border-slate-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"
             data-paintbrush-target="endsAt">
    </div>
    <div>
      <label class="block text-xs font-medium text-slate-500 mb-1">人數</label>
      <input type="number" value="1" min="1" max="20"
             class="w-16 border border-slate-300 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400"
             data-paintbrush-target="headcount">
    </div>
    <button type="button"
            data-action="click->paintbrush#toggle"
            data-paintbrush-target="toggleBtn"
            class="flex items-center gap-2 px-4 py-1.5 rounded-lg border text-sm font-medium transition
                   border-slate-300 bg-white text-slate-600 hover:bg-orange-50 hover:border-orange-300">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <span data-paintbrush-target="toggleLabel">開啟油漆刷</span>
    </button>
    <p class="text-xs text-slate-400 self-center" data-paintbrush-target="hint"></p>
  </div>
</div>

<%# 週曆格 %>
<div class="bg-white rounded-xl border border-slate-200 overflow-hidden" id="week-grid">
  <%# Header row %>
  <div class="grid border-b border-slate-200" style="grid-template-columns: repeat(7, 1fr)">
    <% @week_dates.each do |date| %>
      <% is_today = date == Date.today %>
      <div class="px-3 py-2.5 text-center border-r border-slate-100 last:border-0">
        <div class="text-xs text-slate-400"><%= %w[日 一 二 三 四 五 六][date.wday] %></div>
        <div class="text-sm font-semibold mt-0.5 <%= is_today ? 'text-orange-500' : 'text-slate-700' %>">
          <%= date.strftime("%-m/%-d") %>
          <% if is_today %>
            <span class="block text-xs font-normal text-orange-400">今天</span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# Shift cells %>
  <div class="grid" style="grid-template-columns: repeat(7, 1fr); min-height: 200px;">
    <% @week_dates.each do |date| %>
      <% day_shifts = @shifts_by_date[date] || [] %>
      <div class="border-r border-slate-100 last:border-0 p-2 space-y-1.5 min-h-32 select-none
                  transition-colors duration-100"
           data-paintbrush-target="cell"
           data-date="<%= date %>"
           data-has-shifts="<%= day_shifts.any? %>"
           data-action="mousedown->paintbrush#cellMousedown mouseenter->paintbrush#cellMouseenter">
        <% day_shifts.each do |shift| %>
          <%= link_to shift_path(shift),
                class: "block rounded-lg px-2 py-1.5 text-xs hover:opacity-80 transition
                        #{shift.staffing_status == :understaffed ? 'bg-red-50 border border-red-200' :
                          shift.staffing_status == :overstaffed  ? 'bg-amber-50 border border-amber-200' :
                                                                    'bg-green-50 border border-green-200'}" do %>
            <div class="font-semibold text-slate-700">
              <%= shift.starts_at.strftime("%H:%M") %>–<%= shift.ends_at.strftime("%H:%M") %>
            </div>
            <div class="text-slate-500 truncate"><%= shift.location.name %></div>
            <div class="flex items-center justify-between mt-0.5">
              <span class="text-slate-400"><%= ApplicationHelper::ROLE_TAG_I18N[shift.role_tag] %></span>
              <span class="<%= shift.staffing_status == :understaffed ? 'text-red-500' : shift.staffing_status == :overstaffed ? 'text-amber-500' : 'text-green-600' %>">
                <%= shift.assigned_count %>/<%= shift.required_headcount %>
              </span>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
</div><%# /paintbrush wrapper %>
