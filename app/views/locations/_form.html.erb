<%= render "shared/form_errors", object: location %>

<div class="space-y-4">
  <div>
    <%= f.label :name, "門市名稱", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :name,
          placeholder: "例：信義店、忠孝東路店",
          class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :address, "地址（選填）", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :address,
          placeholder: "例：台北市信義區市府路1號",
          class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit "儲存門市",
          class: "bg-orange-500 hover:bg-orange-600 text-white font-medium px-6 py-2.5 rounded-lg transition cursor-pointer text-sm" %>
    <%= link_to "取消", locations_path,
          class: "px-6 py-2.5 text-sm text-slate-600 hover:text-slate-900 transition" %>
  </div>
</div>
