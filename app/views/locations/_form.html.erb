<%= render "shared/form_errors", object: location %>

<div class="space-y-4">
  <div>
    <%= f.label :name, "門市名稱", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :name,
          placeholder: "例：信義店、忠孝東路店",
          class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :address, "地址（選填）", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= f.text_field :address,
          placeholder: "例：台北市信義區市府路1號",
          class: "w-full border border-slate-300 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent" %>
  </div>

  <div>
    <p class="block text-sm font-medium text-slate-700 mb-3">每週營業時間</p>
    <div class="border border-slate-200 rounded-lg overflow-hidden">
      <div class="grid grid-cols-4 gap-0 bg-slate-50 px-4 py-2 border-b border-slate-200 text-xs font-medium text-slate-500">
        <span>星期</span>
        <span>開店</span>
        <span>關店</span>
        <span class="text-center">公休</span>
      </div>
      <%= f.fields_for :business_hours do |bh| %>
        <div class="grid grid-cols-4 gap-0 items-center px-4 py-2.5 border-b border-slate-100 last:border-0">
          <span class="text-sm text-slate-700 font-medium">
            <%= LocationBusinessHour::DAYS[bh.object.day_of_week] %>
          </span>
          <%= bh.hidden_field :day_of_week %>
          <div>
            <%= bh.time_field :opens_at,
                  value: bh.object.opens_at&.strftime("%H:%M"),
                  class: "w-28 border border-slate-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent disabled:opacity-40",
                  data: { bh_target: "timeField" } %>
          </div>
          <div>
            <%= bh.time_field :closes_at,
                  value: bh.object.closes_at&.strftime("%H:%M"),
                  class: "w-28 border border-slate-300 rounded px-2 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-transparent disabled:opacity-40",
                  data: { bh_target: "timeField" } %>
          </div>
          <div class="flex justify-center">
            <%= bh.check_box :is_closed,
                  class: "w-4 h-4 accent-orange-500",
                  onchange: "this.closest('.grid').querySelectorAll('input[type=time]').forEach(i => i.disabled = this.checked)" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit "儲存門市",
          class: "bg-orange-500 hover:bg-orange-600 text-white font-medium px-6 py-2.5 rounded-lg transition cursor-pointer text-sm" %>
    <%= link_to "取消", locations_path,
          class: "px-6 py-2.5 text-sm text-slate-600 hover:text-slate-900 transition" %>
  </div>
</div>
