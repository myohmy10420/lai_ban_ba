<div style="min-height:100vh;background:#f8fafc;display:flex;align-items:center;justify-content:center;padding:2.5rem 1rem;">
  <div style="width:100%;max-width:780px;background:#fff;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,0.08);border:1px solid #f1f5f9;overflow:hidden;display:flex;min-height:520px;">

    <%# ── Left brand panel ── %>
    <div style="width:42%;min-width:260px;background:linear-gradient(145deg,#fb923c,#ea580c);padding:2.5rem;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden;flex-shrink:0;">
      <div style="position:absolute;width:240px;height:240px;background:rgba(255,255,255,0.10);border-radius:50%;top:-70px;right:-70px;pointer-events:none;"></div>
      <div style="position:absolute;width:150px;height:150px;background:rgba(255,255,255,0.10);border-radius:50%;bottom:50px;left:-50px;pointer-events:none;"></div>
      <div style="position:absolute;width:90px;height:90px;background:rgba(255,255,255,0.10);border-radius:50%;top:48%;right:18px;pointer-events:none;"></div>

      <%# Logo %>
      <div style="display:flex;align-items:center;gap:10px;position:relative;z-index:1;">
        <div style="background:rgba(255,255,255,0.25);border-radius:12px;padding:8px;display:flex;">
          <svg style="width:20px;height:20px;" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <span style="color:#fff;font-size:20px;font-weight:700;letter-spacing:0.02em;">來班吧</span>
      </div>

      <%# Mid content %>
      <div style="position:relative;z-index:1;">
        <span style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;background:rgba(255,255,255,0.20);display:inline-block;padding:4px 12px;border-radius:20px;color:rgba(255,255,255,0.75);">密碼重設</span>
        <h2 style="font-size:26px;font-weight:700;color:#fff;margin:16px 0 10px;line-height:1.4;">忘記密碼了？<br>沒問題！</h2>
        <p style="font-size:14px;color:rgba(255,255,255,0.80);line-height:1.75;margin-bottom:24px;">輸入您的信箱，我們會在幾分鐘內寄送重設連結給您。</p>

        <div style="display:flex;flex-direction:column;gap:12px;">
          <% [["1", "輸入您的電子信箱"], ["2", "收取重設連結郵件"], ["3", "設定並確認新密碼"]].each do |num, text| %>
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:26px;height:26px;border-radius:50%;background:rgba(255,255,255,0.25);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0;"><%= num %></div>
              <span style="font-size:13px;color:rgba(255,255,255,0.90);"><%= text %></span>
            </div>
          <% end %>
        </div>
      </div>

      <p style="color:rgba(255,255,255,0.35);font-size:12px;position:relative;z-index:1;">© <%= Date.today.year %> 來班吧</p>
    </div>

    <%# ── Right form panel ── %>
    <div style="flex:1;padding:2.5rem 2.75rem;display:flex;flex-direction:column;justify-content:center;">

      <div style="width:48px;height:48px;background:#fff7ed;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
        <svg style="width:24px;height:24px;" fill="none" stroke="#f97316" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>

      <h1 style="font-size:22px;font-weight:700;color:#1e293b;margin:0 0 6px;">重設密碼</h1>
      <p style="font-size:14px;color:#94a3b8;margin:0 0 2rem;line-height:1.6;">輸入您的信箱，我們將寄送重設連結至您的信箱。</p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_with(model: resource, scope: resource_name, url: password_path(resource_name), html: { style: "display:flex;flex-direction:column;" }, data: { turbo: false }) do |f| %>

        <div>
          <%= f.label :email, "電子信箱", style: "display:block;font-size:13px;font-weight:600;color:#475569;margin-bottom:6px;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "you@example.com",
              style: "width:100%;padding:11px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;color:#1e293b;outline:none;box-sizing:border-box;",
              onfocus: "this.style.borderColor='#f97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.15)';this.style.background='#fff'",
              onblur:  "this.style.borderColor='#e2e8f0';this.style.boxShadow='none';this.style.background='#f8fafc'" %>
        </div>

        <%= f.submit "發送重設信件",
            style: "width:100%;padding:12px;background:#f97316;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(249,115,22,0.25);margin-top:20px;",
            onmouseover: "this.style.background='#ea580c'",
            onmouseout:  "this.style.background='#f97316'",
            onmousedown: "this.style.transform='scale(0.98)'",
            onmouseup:   "this.style.transform='scale(1)'" %>

      <% end %>

      <%= link_to new_session_path(resource_name),
          style: "display:flex;align-items:center;justify-content:center;gap:6px;margin-top:12px;padding:10px;border:1px solid #e2e8f0;border-radius:10px;font-size:13px;font-weight:500;color:#64748b;text-decoration:none;transition:background .15s;",
          onmouseover: "this.style.background='#f8fafc';this.style.color='#1e293b'",
          onmouseout:  "this.style.background='transparent';this.style.color='#64748b'" do %>
        <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m7-7l-7 7 7 7"/>
        </svg>
        返回登入
      <% end %>

    </div>
  </div>
</div>
