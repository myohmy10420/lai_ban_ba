<div class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 flex items-center justify-center p-4">
  <div class="w-full max-w-md">
    <div class="bg-slate-800 border border-slate-700 shadow-2xl rounded-lg">
      <div class="p-8 space-y-6">
        <div class="space-y-2 text-center">
          <h2 class="text-2xl font-bold text-white">建立新帳號</h2>
          <p class="text-slate-400">加入排班系統</p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), class: "space-y-5") do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <div class="space-y-2">
            <%= f.label :name, "姓名", class: "text-slate-300 block text-sm font-medium" %>
            <%= f.text_field :name, placeholder: "請輸入姓名", class: "w-full bg-slate-700 border border-slate-600 text-white placeholder:text-slate-500 focus:border-blue-500 focus:ring-blue-500 rounded-md px-3 py-2 transition", required: true %>
          </div>

          <div class="space-y-2">
            <%= f.label :email, "電子郵件", class: "text-slate-300 block text-sm font-medium" %>
            <%= f.email_field :email, placeholder: "your@email.com", class: "w-full bg-slate-700 border border-slate-600 text-white placeholder:text-slate-500 focus:border-blue-500 focus:ring-blue-500 rounded-md px-3 py-2 transition", autofocus: true, autocomplete: "email", required: true %>
          </div>

          <div class="space-y-2">
            <%= f.label :password, "密碼", class: "text-slate-300 block text-sm font-medium" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-slate-400">最少 <%= @minimum_password_length %> 個字元</p>
            <% end %>
            <%= f.password_field :password, placeholder: "••••••••", class: "w-full bg-slate-700 border border-slate-600 text-white placeholder:text-slate-500 focus:border-blue-500 focus:ring-blue-500 rounded-md px-3 py-2 transition", autocomplete: "new-password", required: true %>
          </div>

          <div class="space-y-2">
            <%= f.label :password_confirmation, "確認密碼", class: "text-slate-300 block text-sm font-medium" %>
            <%= f.password_field :password_confirmation, placeholder: "••••••••", class: "w-full bg-slate-700 border border-slate-600 text-white placeholder:text-slate-500 focus:border-blue-500 focus:ring-blue-500 rounded-md px-3 py-2 transition", autocomplete: "new-password", required: true %>
          </div>

          <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 text-white font-semibold py-2 rounded-lg transition">
            建立帳號
          </button>
        <% end %>

        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
