<div style="min-height:100vh;background:#f8fafc;display:flex;align-items:center;justify-content:center;padding:2.5rem 1rem;">
  <div style="width:100%;max-width:780px;background:#fff;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,0.08);border:1px solid #f1f5f9;overflow:hidden;display:flex;min-height:580px;">

    <%# ── Left brand panel ── %>
    <div style="width:42%;min-width:260px;background:linear-gradient(145deg,#fb923c,#ea580c);padding:2.5rem;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden;flex-shrink:0;">
      <div style="position:absolute;width:240px;height:240px;background:rgba(255,255,255,0.10);border-radius:50%;top:-70px;right:-70px;pointer-events:none;"></div>
      <div style="position:absolute;width:150px;height:150px;background:rgba(255,255,255,0.10);border-radius:50%;bottom:50px;left:-50px;pointer-events:none;"></div>
      <div style="position:absolute;width:90px;height:90px;background:rgba(255,255,255,0.10);border-radius:50%;top:48%;right:18px;pointer-events:none;"></div>

      <%# Logo %>
      <div style="display:flex;align-items:center;gap:10px;position:relative;z-index:1;">
        <div style="background:rgba(255,255,255,0.25);border-radius:12px;padding:8px;display:flex;">
          <svg style="width:20px;height:20px;" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <span style="color:#fff;font-size:20px;font-weight:700;letter-spacing:0.02em;">來班吧</span>
      </div>

      <%# Mid content %>
      <div style="position:relative;z-index:1;">
        <span style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;background:rgba(255,255,255,0.20);display:inline-block;padding:4px 12px;border-radius:20px;color:rgba(255,255,255,0.75);">免費開始使用</span>
        <h2 style="font-size:26px;font-weight:700;color:#fff;margin:16px 0 10px;line-height:1.4;">加入來班吧，<br>輕鬆掌握班表</h2>
        <p style="font-size:14px;color:rgba(255,255,255,0.80);line-height:1.75;margin-bottom:24px;">幾分鐘內完成設定，<br>立即體驗智慧排班的便利。</p>

        <div style="display:flex;flex-direction:column;gap:12px;">
          <% [
            ["M5 13l4 4L19 7", "免費試用，不需信用卡"],
            ["M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z", "資料安全加密保護"],
            ["M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z", "隨時聯繫客服支援"]
          ].each do |path, label| %>
            <div style="display:flex;align-items:flex-start;gap:10px;">
              <div style="width:28px;height:28px;border-radius:8px;background:rgba(255,255,255,0.20);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">
                <svg style="width:14px;height:14px;" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/>
                </svg>
              </div>
              <span style="font-size:13px;color:rgba(255,255,255,0.90);line-height:1.5;padding-top:5px;"><%= label %></span>
            </div>
          <% end %>
        </div>
      </div>

      <p style="color:rgba(255,255,255,0.35);font-size:12px;position:relative;z-index:1;">© <%= Date.today.year %> 來班吧</p>
    </div>

    <%# ── Right form panel ── %>
    <div style="flex:1;padding:2.5rem 2.75rem;display:flex;flex-direction:column;justify-content:center;">

      <%# Icon badge %>
      <div style="width:48px;height:48px;background:#fff7ed;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
        <svg style="width:24px;height:24px;" fill="none" stroke="#f97316" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
        </svg>
      </div>

      <h1 style="font-size:22px;font-weight:700;color:#1e293b;margin:0 0 6px;">建立帳號</h1>
      <p style="font-size:14px;color:#94a3b8;margin:0 0 1.75rem;line-height:1.6;">
        已有帳號？
        <%= link_to "直接登入", new_session_path(resource_name), style: "color:#f97316;font-weight:600;text-decoration:none;" %>
      </p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_with(model: resource, scope: resource_name, url: registration_path(resource_name), html: { style: "display:flex;flex-direction:column;gap:16px;" }, data: { turbo: false }) do |f| %>

        <%# Email %>
        <div>
          <%= f.label :email, "電子信箱", style: "display:block;font-size:13px;font-weight:600;color:#475569;margin-bottom:6px;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "you@example.com",
              style: "width:100%;padding:11px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;color:#1e293b;outline:none;box-sizing:border-box;",
              onfocus: "this.style.borderColor='#f97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.15)';this.style.background='#fff'",
              onblur:  "this.style.borderColor='#e2e8f0';this.style.boxShadow='none';this.style.background='#f8fafc'" %>
        </div>

        <%# Password with strength meter %>
        <div data-controller="password-visibility">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
            <%= f.label :password, "設定密碼", style: "font-size:13px;font-weight:600;color:#475569;" %>
            <% if @minimum_password_length %>
              <span style="font-size:12px;color:#cbd5e1;">最少 <%= @minimum_password_length %> 個字元</span>
            <% end %>
          </div>
          <div style="position:relative;">
            <%= f.password_field :password, autocomplete: "new-password",
                id: "reg_password_field",
                data: { password_visibility_target: "input" },
                placeholder: "••••••••",
                style: "width:100%;padding:11px 42px 11px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;color:#1e293b;outline:none;box-sizing:border-box;",
                onfocus: "this.style.borderColor='#f97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.15)';this.style.background='#fff'",
                onblur:  "this.style.borderColor='#e2e8f0';this.style.boxShadow='none';this.style.background='#f8fafc'" %>
            <button type="button" data-action="click->password-visibility#toggle"
                style="position:absolute;top:0;bottom:0;right:0;padding:0 12px;display:flex;align-items:center;background:none;border:none;cursor:pointer;color:#cbd5e1;"
                onmouseover="this.style.color='#f97316'" onmouseout="this.style.color='#cbd5e1'">
              <svg data-password-visibility-target="icon" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
          <%# Strength meter %>
          <div style="display:flex;gap:4px;margin:8px 0 4px;">
            <div id="reg-s1" style="flex:1;height:3px;border-radius:2px;background:#e2e8f0;transition:background .3s;"></div>
            <div id="reg-s2" style="flex:1;height:3px;border-radius:2px;background:#e2e8f0;transition:background .3s;"></div>
            <div id="reg-s3" style="flex:1;height:3px;border-radius:2px;background:#e2e8f0;transition:background .3s;"></div>
            <div id="reg-s4" style="flex:1;height:3px;border-radius:2px;background:#e2e8f0;transition:background .3s;"></div>
          </div>
          <p id="reg-slbl" style="font-size:12px;color:#cbd5e1;">輸入密碼以查看強度</p>
        </div>

        <%# Password confirmation %>
        <div data-controller="password-visibility">
          <%= f.label :password_confirmation, "確認密碼", style: "display:block;font-size:13px;font-weight:600;color:#475569;margin-bottom:6px;" %>
          <div style="position:relative;">
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                data: { password_visibility_target: "input" },
                placeholder: "••••••••",
                style: "width:100%;padding:11px 42px 11px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;color:#1e293b;outline:none;box-sizing:border-box;",
                onfocus: "this.style.borderColor='#f97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.15)';this.style.background='#fff'",
                onblur:  "this.style.borderColor='#e2e8f0';this.style.boxShadow='none';this.style.background='#f8fafc'" %>
            <button type="button" data-action="click->password-visibility#toggle"
                style="position:absolute;top:0;bottom:0;right:0;padding:0 12px;display:flex;align-items:center;background:none;border:none;cursor:pointer;color:#cbd5e1;"
                onmouseover="this.style.color='#f97316'" onmouseout="this.style.color='#cbd5e1'">
              <svg data-password-visibility-target="icon" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
        </div>

        <%= f.submit "立即註冊",
            style: "width:100%;padding:12px;background:#f97316;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(249,115,22,0.25);margin-top:4px;",
            onmouseover: "this.style.background='#ea580c'",
            onmouseout:  "this.style.background='#f97316'",
            onmousedown: "this.style.transform='scale(0.98)'",
            onmouseup:   "this.style.transform='scale(1)'" %>

      <% end %>

      <p style="font-size:12px;color:#cbd5e1;text-align:center;margin-top:16px;line-height:1.7;">
        註冊即代表您同意
        <a href="#" style="color:#cbd5e1;text-decoration:underline;">服務條款</a>
        與
        <a href="#" style="color:#cbd5e1;text-decoration:underline;">隱私權政策</a>
      </p>
    </div>

  </div>
</div>

<script>
(function(){
  var inp = document.getElementById('reg_password_field');
  if (!inp) return;
  var segs = [1,2,3,4].map(function(i){ return document.getElementById('reg-s'+i); });
  var lbl  = document.getElementById('reg-slbl');
  var colors = ['', '#ef4444', '#f97316', '#eab308', '#22c55e'];
  var labels = ['輸入密碼以查看強度', '弱', '普通', '良好', '強'];

  inp.addEventListener('input', function(){
    var v = inp.value, score = 0;
    if (v.length >= 8)    score++;
    if (/[a-z]/.test(v))  score++;
    if (/[A-Z]/.test(v))  score++;
    if (/[0-9]/.test(v))  score++;

    segs.forEach(function(s, i){
      s.style.background = (i < score) ? colors[score] : '#e2e8f0';
    });
    lbl.textContent = v.length ? labels[score] : labels[0];
    lbl.style.color  = v.length ? colors[score] : '#cbd5e1';
  });
})();
</script>
