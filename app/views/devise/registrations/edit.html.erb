<div class="mx-auto w-full max-w-2xl px-4 py-8">
  <div class="bg-white rounded-2xl shadow-xl shadow-orange-100 border border-slate-100 overflow-hidden">
    <!-- 卡片標題 -->
    <div class="bg-slate-50 px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
        <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        帳號設定
      </h3>
      <span class="text-xs font-medium px-2 py-1 bg-orange-100 text-orange-700 rounded-lg">會員資料</span>
    </div>

    <div class="p-6 sm:p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-6" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="grid grid-cols-1 gap-6">
          <!-- Email 區域 -->
          <div>
            <%= f.label :email, "電子信箱", class: "block text-sm font-bold text-slate-700 mb-1" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "appearance-none block w-full px-3 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm transition" %>
            
            <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
              <div class="mt-3 text-sm text-orange-700 bg-orange-50 p-3 rounded-lg border border-orange-100 flex items-start gap-2">
                <svg class="w-5 h-5 text-orange-500 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span>等待確認新信箱： <span class="font-bold"><%= resource.unconfirmed_email %></span></span>
              </div>
            <% end %>
          </div>

          <div class="border-t border-slate-100 my-2"></div>

          <!-- 變更密碼區域 -->
          <div>
            <h4 class="text-sm font-bold text-slate-900 mb-4 flex items-center">
              <svg class="w-4 h-4 mr-2 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              變更密碼 <span class="ml-2 text-xs font-normal text-slate-400">(若不修改請留空)</span>
            </h4>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div data-controller="password-visibility">
                <%= f.label :password, "新密碼", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1" %>
                <div class="relative rounded-xl shadow-sm">
                  <%= f.password_field :password, autocomplete: "new-password", data: { password_visibility_target: "input" }, class: "appearance-none block w-full px-3 py-2.5 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm pr-10 transition" %>
                  <button type="button" data-action="click->password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-orange-500 cursor-pointer focus:outline-none">
                    <svg data-password-visibility-target="icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                  </button>
                </div>
                <% if @minimum_password_length %>
                  <p class="mt-1 text-xs text-slate-400">最少 <%= @minimum_password_length %> 個字元</p>
                <% end %>
              </div>

              <div data-controller="password-visibility">
                <%= f.label :password_confirmation, "確認新密碼", class: "block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1" %>
                <div class="relative rounded-xl shadow-sm">
                  <%= f.password_field :password_confirmation, autocomplete: "new-password", data: { password_visibility_target: "input" }, class: "appearance-none block w-full px-3 py-2.5 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm pr-10 transition" %>
                  <button type="button" data-action="click->password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-orange-500 cursor-pointer focus:outline-none">
                    <svg data-password-visibility-target="icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="border-t border-slate-100 my-2"></div>

          <!-- 目前密碼驗證 (Devise 安全要求) -->
          <div class="bg-slate-50 p-5 rounded-xl border border-slate-200">
            <div data-controller="password-visibility">
              <%= f.label :current_password, class: "block text-sm font-bold text-slate-800 mb-1" do %>
                目前密碼 <span class="text-xs font-normal text-red-500 ml-1">* (變更資料需輸入目前密碼以確認身份)</span>
              <% end %>
              <div class="relative rounded-xl shadow-sm mt-2">
                <%= f.password_field :current_password, autocomplete: "current-password", data: { password_visibility_target: "input" }, class: "appearance-none block w-full px-3 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm pr-10 transition bg-white" %>
                <button type="button" data-action="click->password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-orange-500 cursor-pointer focus:outline-none">
                   <svg data-password-visibility-target="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row items-center gap-4 pt-4">
          <%= f.submit "更新資料", class: "w-full sm:flex-1 flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-md shadow-orange-200 text-sm font-bold text-white bg-orange-500 hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition transform hover:-translate-y-0.5 active:translate-y-0 cursor-pointer" %>
          
          <%= link_to "返回", :back, class: "w-full sm:w-auto py-3 px-6 border border-slate-300 rounded-xl text-sm font-bold text-slate-600 bg-white hover:bg-slate-50 focus:outline-none transition text-center cursor-pointer" %>
        </div>
      <% end %>
    </div>
    
    <!-- 危險區域：刪除帳號 -->
    <div class="bg-red-50/50 border-t border-red-100 px-6 py-4">
        <h4 class="text-xs font-bold text-red-800 uppercase tracking-wider mb-2">危險操作</h4>
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <p class="text-sm text-red-600/80">刪除帳號是不可逆的動作，所有資料將會遺失。</p>
            <%= button_to "刪除帳號", registration_path(resource_name), data: { confirm: "您確定要刪除帳號嗎？此動作無法復原。", turbo_confirm: "您確定要刪除帳號嗎？此動作無法復原。" }, method: :delete, class: "text-sm text-red-600 font-bold hover:text-red-800 hover:bg-red-100 px-3 py-2 rounded-lg transition border border-red-200 hover:border-red-300 bg-white" %>
        </div>
    </div>
  </div>
</div>
