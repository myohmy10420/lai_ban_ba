<div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden w-full">
  <!-- 背景裝飾 -->
  <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-orange-100 rounded-full blur-3xl opacity-50 pointer-events-none z-0"></div>
  <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-yellow-100 rounded-full blur-3xl opacity-50 pointer-events-none z-0"></div>

  <!-- 標題區域 -->
  <div class="mx-auto w-full max-w-md relative z-10">
    <div class="flex justify-center items-center gap-2 mb-6">
      <div class="bg-orange-500 p-1.5 rounded-lg shadow-md shadow-orange-200">
        <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
      </div>
      <span class="font-bold text-2xl tracking-tight text-orange-600">來班吧</span>
    </div>
    <h2 class="text-center text-3xl font-extrabold text-slate-900">
      歡迎回來
    </h2>
    <p class="mt-2 text-center text-sm text-slate-600">
      還沒有帳號嗎？
      <a href="<%= new_registration_path(resource_name) %>" class="font-medium text-orange-600 hover:text-orange-500 transition underline decoration-transparent hover:decoration-orange-500 underline-offset-4">
        免費註冊試用
      </a>
    </p>
  </div>

  <!-- 表單區域 -->
  <div class="mt-8 mx-auto w-full max-w-md relative z-10">
    <div class="bg-white py-8 px-4 shadow-xl shadow-orange-100/50 rounded-2xl sm:px-10 border border-slate-100">
      <%= form_with(model: resource, scope: resource_name, url: session_path(resource_name), html: { class: "space-y-6" }, data: { turbo: false }) do |f| %>
        
        <!-- Flash Messages Area if needed inside card, otherwise usually in layout -->
        
        <!-- Email -->
        <div>
          <%= f.label :email, "電子信箱", class: "block text-sm font-bold text-slate-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "appearance-none block w-full px-3 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm transition ease-in-out duration-150" %>
        </div>

        <!-- Password -->
        <div data-controller="password-visibility">
          <div class="flex justify-between items-center mb-1">
            <%= f.label :password, "密碼", class: "block text-sm font-bold text-slate-700" %>
            <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
              <%= link_to "忘記密碼？", new_password_path(resource_name), class: "text-sm font-medium text-slate-400 hover:text-orange-600 transition" %>
            <% end %>
          </div>
          <div class="relative rounded-xl shadow-sm">
            <%= f.password_field :password, autocomplete: "current-password", data: { password_visibility_target: "input" }, class: "appearance-none block w-full px-3 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-orange-500 sm:text-sm pr-10 transition ease-in-out duration-150" %>
            <button type="button" data-action="click->password-visibility#toggle" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-orange-500 cursor-pointer focus:outline-none transition-colors">
              <!-- Eye Icon -->
              <svg data-password-visibility-target="icon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>
        </div>

        <!-- Remember Me -->
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "h-4 w-4 text-orange-600 focus:ring-orange-500 border-slate-300 rounded cursor-pointer transition" %>
            <%= f.label :remember_me, "記住我", class: "ml-2 block text-sm text-slate-600 cursor-pointer select-none" %>
          </div>
        <% end %>

        <div>
          <%= f.submit "登入系統", class: "w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-md shadow-orange-200 text-sm font-bold text-white bg-orange-500 hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange-500 transition transform hover:-translate-y-0.5 active:translate-y-0" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
