<div style="min-height:100vh;background:#f8fafc;display:flex;align-items:center;justify-content:center;padding:2.5rem 1rem;">
  <div style="width:100%;max-width:780px;background:#fff;border-radius:20px;box-shadow:0 20px 60px rgba(0,0,0,0.08);border:1px solid #f1f5f9;overflow:hidden;display:flex;min-height:560px;">

    <%# ── Left brand panel ── %>
    <div style="width:42%;min-width:260px;background:linear-gradient(145deg,#fb923c,#ea580c);padding:2.5rem;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden;flex-shrink:0;">
      <div style="position:absolute;width:240px;height:240px;background:rgba(255,255,255,0.10);border-radius:50%;top:-70px;right:-70px;pointer-events:none;"></div>
      <div style="position:absolute;width:150px;height:150px;background:rgba(255,255,255,0.10);border-radius:50%;bottom:50px;left:-50px;pointer-events:none;"></div>
      <div style="position:absolute;width:90px;height:90px;background:rgba(255,255,255,0.10);border-radius:50%;top:48%;right:18px;pointer-events:none;"></div>

      <%# Logo %>
      <div style="display:flex;align-items:center;gap:10px;position:relative;z-index:1;">
        <div style="background:rgba(255,255,255,0.25);border-radius:12px;padding:8px;display:flex;">
          <svg style="width:20px;height:20px;" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <span style="color:#fff;font-size:20px;font-weight:700;letter-spacing:0.02em;">來班吧</span>
      </div>

      <%# Mid content %>
      <div style="position:relative;z-index:1;color:#fff;">
        <span style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;background:rgba(255,255,255,0.20);display:inline-block;padding:4px 12px;border-radius:20px;color:rgba(255,255,255,0.75);">員工排班系統</span>
        <h2 style="font-size:26px;font-weight:700;margin:16px 0 10px;line-height:1.4;color:#fff;">歡迎回來！<br>輕鬆管理您的班表</h2>
        <p style="font-size:14px;color:rgba(255,255,255,0.80);line-height:1.75;margin-bottom:24px;">一站式排班、打卡與薪資管理，<br>讓店務運作更順暢。</p>

        <div style="display:flex;flex-direction:column;gap:12px;">
          <% [
            ["M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z", "智慧排班，秒速完成"],
            ["M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", "即時打卡紀錄"],
            ["M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z", "薪資自動計算"]
          ].each do |path, label| %>
            <div style="display:flex;align-items:center;gap:10px;">
              <div style="width:28px;height:28px;border-radius:8px;background:rgba(255,255,255,0.20);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <svg style="width:14px;height:14px;" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="<%= path %>"/>
                </svg>
              </div>
              <span style="font-size:13px;color:rgba(255,255,255,0.90);"><%= label %></span>
            </div>
          <% end %>
        </div>
      </div>

      <p style="color:rgba(255,255,255,0.35);font-size:12px;position:relative;z-index:1;">© <%= Date.today.year %> 來班吧</p>
    </div>

    <%# ── Right form panel ── %>
    <div style="flex:1;padding:2.5rem 2.75rem;display:flex;flex-direction:column;justify-content:center;">

      <div style="width:48px;height:48px;background:#fff7ed;border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
        <svg style="width:24px;height:24px;" fill="none" stroke="#f97316" stroke-width="1.8" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
      </div>

      <h1 style="font-size:22px;font-weight:700;color:#1e293b;margin:0 0 6px;">登入帳號</h1>
      <p style="font-size:14px;color:#94a3b8;margin:0 0 2rem;line-height:1.6;">
        還沒有帳號？
        <%= link_to "免費註冊", new_registration_path(resource_name), style: "color:#f97316;font-weight:600;text-decoration:none;" %>
      </p>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_with(model: resource, scope: resource_name, url: session_path(resource_name), html: { style: "display:flex;flex-direction:column;gap:20px;" }, data: { turbo: false }) do |f| %>

        <%# Email %>
        <div>
          <%= f.label :email, "電子信箱", style: "display:block;font-size:13px;font-weight:600;color:#475569;margin-bottom:6px;" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "you@example.com",
              style: "width:100%;padding:11px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;color:#1e293b;outline:none;box-sizing:border-box;",
              onfocus: "this.style.borderColor='#f97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.15)';this.style.background='#fff'",
              onblur:  "this.style.borderColor='#e2e8f0';this.style.boxShadow='none';this.style.background='#f8fafc'" %>
        </div>

        <%# Password %>
        <div data-controller="password-visibility">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
            <%= f.label :password, "密碼", style: "font-size:13px;font-weight:600;color:#475569;" %>
            <% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
              <%= link_to "忘記密碼？", new_password_path(resource_name),
                  style: "font-size:12px;color:#94a3b8;text-decoration:none;",
                  onmouseover: "this.style.color='#f97316'",
                  onmouseout:  "this.style.color='#94a3b8'" %>
            <% end %>
          </div>
          <div style="position:relative;">
            <%= f.password_field :password, autocomplete: "current-password",
                data: { password_visibility_target: "input" },
                placeholder: "••••••••",
                style: "width:100%;padding:11px 42px 11px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;font-size:14px;color:#1e293b;outline:none;box-sizing:border-box;",
                onfocus: "this.style.borderColor='#f97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.15)';this.style.background='#fff'",
                onblur:  "this.style.borderColor='#e2e8f0';this.style.boxShadow='none';this.style.background='#f8fafc'" %>
            <button type="button" data-action="click->password-visibility#toggle"
                style="position:absolute;top:0;bottom:0;right:0;padding:0 12px;display:flex;align-items:center;background:none;border:none;cursor:pointer;color:#cbd5e1;"
                onmouseover="this.style.color='#f97316'" onmouseout="this.style.color='#cbd5e1'">
              <svg data-password-visibility-target="icon" style="width:16px;height:16px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
        </div>

        <%# Remember me %>
        <% if devise_mapping.rememberable? %>
          <div style="display:flex;align-items:center;gap:8px;">
            <%= f.check_box :remember_me, style: "width:16px;height:16px;accent-color:#f97316;cursor:pointer;flex-shrink:0;" %>
            <%= f.label :remember_me, "記住我", style: "font-size:13px;color:#64748b;cursor:pointer;user-select:none;" %>
          </div>
        <% end %>

        <%= f.submit "登入",
            style: "width:100%;padding:12px;background:#f97316;color:#fff;border:none;border-radius:10px;font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 14px rgba(249,115,22,0.25);",
            onmouseover: "this.style.background='#ea580c'",
            onmouseout:  "this.style.background='#f97316'",
            onmousedown: "this.style.transform='scale(0.98)'",
            onmouseup:   "this.style.transform='scale(1)'" %>

      <% end %>
    </div>

  </div>
</div>
