<div class="relative">
  <div class="absolute inset-0 flex items-center">
    <div class="w-full border-t border-slate-600"></div>
  </div>
  <div class="relative flex justify-center text-sm">
    <span class="px-2 bg-slate-800 text-slate-400">或</span>
  </div>
</div>

<div class="space-y-3 text-center text-sm">
  <%- if controller_name != 'sessions' %>
    <%= link_to "登入帳號", new_session_path(resource_name), class: "text-blue-400 hover:text-blue-300 font-semibold transition" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "建立新帳號", new_registration_path(resource_name), class: "text-blue-400 hover:text-blue-300 font-semibold transition" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "忘記密碼?", new_password_path(resource_name), class: "text-blue-400 hover:text-blue-300 font-semibold transition" %>
  <% end %>
</div>
