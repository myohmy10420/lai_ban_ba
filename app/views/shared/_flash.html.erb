<% flash.each do |type, message| %>
  <% bg = type.to_s == "alert" ? "bg-red-50 border-red-200 text-red-800" : "bg-green-50 border-green-200 text-green-800" %>
  <div class="<%= bg %> border rounded-lg px-4 py-3 flex items-start justify-between gap-3 mb-2"
       data-controller="flash" data-action="click->flash#dismiss">
    <span class="text-sm"><%= message %></span>
    <button class="opacity-50 hover:opacity-100 flex-shrink-0 mt-0.5">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>
